# Ramble — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# -----------------------------------------------------------------------
# Google Maps JavaScript API
# Used by the Maps JS loader in the browser (client-side only).
# Restrict this key to your domain(s) in Google Cloud Console:
#   - localhost:3000/* (development)
#   - yourdomain.app/* (production)
# API restriction: Maps JavaScript API only
# -----------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------
# Google Places API
# Used only by server-side Route Handlers. Never exposed to the browser.
# Restrict this key to your server IP in Google Cloud Console.
# API restrictions: Places API (New), Geocoding API
# -----------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
